{
  "id": "asteroids",
  "title": "Asteroids",
  "description": "A classic space shooter where you destroy asteroids.",
  "htmlCode": "\n<!DOCTYPE html>\n<html>\n<head>\n    <style>\n        body { \n            display: flex; flex-direction: column; align-items: center; \n            background: #111; color: white; font-family: sans-serif;\n            margin: 0; padding: 20px;\n        }\n        canvas { background: #000; border: 2px solid #444; box-shadow: 0 0 10px rgba(0,0,0,0.5); }\n        #score-board { display: flex; justify-content: space-between; width: 400px; margin-bottom: 10px; }\n        .controls { margin-top: 20px; display: grid; grid-template-columns: 50px 50px 50px; gap: 10px; }\n        .btn { padding: 15px; background: #444; border: none; color: white; border-radius: 5px; cursor: pointer; user-select: none; }\n        .btn:active { background: #666; }\n        #btn-up { grid-column: 2; }\n        #btn-left { grid-column: 1; grid-row: 2; }\n        #btn-shoot { grid-column: 2; grid-row: 2; }\n        #btn-right { grid-column: 3; grid-row: 2; }\n    </style>\n</head>\n<body>\n    <h2 id=\"level-title\">Asteroids Game</h2>\n    <div id=\"score-board\">\n        <span id=\"score-text\">Score: 0</span>\n        <span id=\"high-score-text\">High Score: 0</span>\n    </div>\n    <canvas id=\"gameCanvas\" width=\"400\" height=\"400\"></canvas>\n    \n    <div class=\"controls\">\n        <button class=\"btn\" id=\"btn-up\">▲</button>\n        <button class=\"btn\" id=\"btn-left\">◀</button>\n        <button class=\"btn\" id=\"btn-shoot\">O</button>\n        <button class=\"btn\" id=\"btn-right\">▶</button>\n    </div>\n\n    <script>\n        const canvas = document.getElementById(\"gameCanvas\");\n        const ctx = canvas.getContext(\"2d\");\n        \n        let score = 0;\n        let highScore = 0;\n        let isGameOver = false;\n        let animationId;\n        \n        // Ship\n        let ship = {\n            x: canvas.width / 2,\n            y: canvas.height / 2,\n            r: 10,\n            a: 0,\n            rotation: 0,\n            thrusting: false,\n            thrust: { x: 0, y: 0 }\n        };\n        const SHIP_THRUST = 0.1;\n        const FRICTION = 0.98;\n        const TURN_SPEED = 0.1;\n        \n        // Bullets\n        let bullets = [];\n        const BULLET_SPEED = 5;\n        const BULLET_MAX = 10;\n        \n        // Asteroids\n        let asteroids = [];\n        let roidsTotal = 5;\n        let roidsSpeed = 1;\n        let roidsSize = 40;\n        \n        const updateScoreDisplays = () => {\n            document.getElementById('score-text').innerText = 'Score: ' + score;\n            document.getElementById('high-score-text').innerText = 'High Score: ' + highScore;\n        };\n\n        const createAsteroids = () => {\n            asteroids = [];\n            for (let i = 0; i < roidsTotal; i++) {\n                let x, y;\n                do {\n                    x = Math.floor(Math.random() * canvas.width);\n                    y = Math.floor(Math.random() * canvas.height);\n                } while (distBetweenPoints(ship.x, ship.y, x, y) < roidsSize * 2 + ship.r);\n                \n                asteroids.push(newAsteroid(x, y, Math.ceil(roidsSize / 2)));\n            }\n        };\n\n        const newAsteroid = (x, y, r) => {\n            let a = Math.random() * Math.PI * 2;\n            let spd = Math.random() * roidsSpeed + roidsSpeed * 0.5;\n            return {\n                x: x,\n                y: y,\n                xv: Math.cos(a) * spd,\n                yv: Math.sin(a) * spd,\n                r: r,\n                a: Math.random() * Math.PI * 2,\n                vert: Math.floor(Math.random() * 5 + 5),\n                offs: []\n            };\n        };\n\n        const distBetweenPoints = (x1, y1, x2, y2) => {\n            return Math.sqrt(Math.pow(x2 - x1, 2) + Math.pow(y2 - y1, 2));\n        };\n\n        const resetGame = () => {\n            ship = {\n                x: canvas.width / 2,\n                y: canvas.height / 2,\n                r: 10,\n                a: 0,\n                rotation: 0,\n                thrusting: false,\n                thrust: { x: 0, y: 0 }\n            };\n            bullets = [];\n            score = 0;\n            isGameOver = false;\n            createAsteroids();\n            updateScoreDisplays();\n            if(animationId) cancelAnimationFrame(animationId);\n            gameLoop();\n        };\n\n        const shoot = () => {\n            if (bullets.length < BULLET_MAX) {\n                bullets.push({\n                    x: ship.x + Math.cos(ship.a) * ship.r,\n                    y: ship.y + Math.sin(ship.a) * ship.r,\n                    xv: Math.cos(ship.a) * BULLET_SPEED,\n                    yv: Math.sin(ship.a) * BULLET_SPEED\n                });\n            }\n        };\n\n        const saveProgress = async () => {\n            if (window.GameAPI) {\n                await window.GameAPI.setProgress(JSON.stringify({ highScore }));\n            }\n        };\n\n        const drawShip = () => {\n            ctx.strokeStyle = \"white\";\n            ctx.lineWidth = 1.5;\n            ctx.beginPath();\n            ctx.moveTo(\n                ship.x + 4/3 * ship.r * Math.cos(ship.a),\n                ship.y + 4/3 * ship.r * Math.sin(ship.a)\n            );\n            ctx.lineTo(\n                ship.x - ship.r * (2/3 * Math.cos(ship.a) + Math.sin(ship.a)),\n                ship.y - ship.r * (2/3 * Math.sin(ship.a) - Math.cos(ship.a))\n            );\n            ctx.lineTo(\n                ship.x - ship.r * (2/3 * Math.cos(ship.a) - Math.sin(ship.a)),\n                ship.y - ship.r * (2/3 * Math.sin(ship.a) + Math.cos(ship.a))\n            );\n            ctx.closePath();\n            ctx.stroke();\n        };\n\n        const drawAsteroids = () => {\n            ctx.strokeStyle = \"slategrey\";\n            ctx.lineWidth = 1.5;\n            for (let i = 0; i < asteroids.length; i++) {\n                let a = asteroids[i];\n                ctx.beginPath();\n                for (let j = 0; j < a.vert; j++) {\n                    ctx.lineTo(\n                        a.x + a.r * Math.cos(a.a + j * Math.PI * 2 / a.vert),\n                        a.y + a.r * Math.sin(a.a + j * Math.PI * 2 / a.vert)\n                    );\n                }\n                ctx.closePath();\n                ctx.stroke();\n            }\n        };\n\n        const updateAsteroids = () => {\n            for (let i = 0; i < asteroids.length; i++) {\n                let a = asteroids[i];\n                a.x += a.xv;\n                a.y += a.yv;\n                if (a.x < 0 - a.r) a.x = canvas.width + a.r;\n                else if (a.x > canvas.width + a.r) a.x = 0 - a.r;\n                if (a.y < 0 - a.r) a.y = canvas.height + a.r;\n                else if (a.y > canvas.height + a.r) a.y = 0 - a.r;\n            }\n        };\n\n        const drawBullets = () => {\n            ctx.fillStyle = \"red\";\n            for (let i = 0; i < bullets.length; i++) {\n                ctx.beginPath();\n                ctx.arc(bullets[i].x, bullets[i].y, 2, 0, Math.PI * 2);\n                ctx.fill();\n            }\n        };\n\n        const updateBullets = () => {\n            for (let i = bullets.length - 1; i >= 0; i--) {\n                bullets[i].x += bullets[i].xv;\n                bullets[i].y += bullets[i].yv;\n                \n                if (bullets[i].x < 0 || bullets[i].x > canvas.width || \n                    bullets[i].y < 0 || bullets[i].y > canvas.height) {\n                    bullets.splice(i, 1);\n                    continue;\n                }\n                \n                // Bullet collision with asteroids\n                for (let j = asteroids.length - 1; j >= 0; j--) {\n                    if (distBetweenPoints(bullets[i].x, bullets[i].y, asteroids[j].x, asteroids[j].y) < asteroids[j].r) {\n                        score += 10;\n                        if(score > highScore) {\n                            highScore = score;\n                            saveProgress();\n                        }\n                        updateScoreDisplays();\n                        \n                        // Split asteroid\n                        if (asteroids[j].r > 10) {\n                            asteroids.push(newAsteroid(asteroids[j].x, asteroids[j].y, asteroids[j].r / 2));\n                            asteroids.push(newAsteroid(asteroids[j].x, asteroids[j].y, asteroids[j].r / 2));\n                        }\n                        asteroids.splice(j, 1);\n                        bullets.splice(i, 1);\n                        \n                        if (asteroids.length === 0) {\n                            roidsTotal++;\n                            createAsteroids();\n                        }\n                        break;\n                    }\n                }\n            }\n        };\n\n        const checkCollisions = () => {\n            for (let i = 0; i < asteroids.length; i++) {\n                if (distBetweenPoints(ship.x, ship.y, asteroids[i].x, asteroids[i].y) < ship.r + asteroids[i].r) {\n                    isGameOver = true;\n                }\n            }\n        };\n\n        const gameLoop = () => {\n            if (isGameOver) {\n                ctx.fillStyle = \"rgba(0,0,0,0.7)\";\n                ctx.fillRect(0,0, canvas.width, canvas.height);\n                ctx.fillStyle = \"white\";\n                ctx.font = \"30px Arial\";\n                ctx.textAlign = \"center\";\n                ctx.fillText(\"Game Over!\", canvas.width/2, canvas.height/2);\n                ctx.font = \"16px Arial\";\n                ctx.fillText(\"Tap or press Space to restart\", canvas.width/2, canvas.height/2 + 30);\n                return;\n            }\n\n            // Move ship\n            if (ship.thrusting) {\n                ship.thrust.x += SHIP_THRUST * Math.cos(ship.a);\n                ship.thrust.y += SHIP_THRUST * Math.sin(ship.a);\n            } else {\n                ship.thrust.x -= FRICTION * ship.thrust.x / 60;\n                ship.thrust.y -= FRICTION * ship.thrust.y / 60;\n            }\n            \n            ship.a += ship.rotation;\n            ship.x += ship.thrust.x;\n            ship.y += ship.thrust.y;\n            \n            // Screen wrap\n            if (ship.x < 0 - ship.r) ship.x = canvas.width + ship.r;\n            else if (ship.x > canvas.width + ship.r) ship.x = 0 - ship.r;\n            if (ship.y < 0 - ship.r) ship.y = canvas.height + ship.r;\n            else if (ship.y > canvas.height + ship.r) ship.y = 0 - ship.r;\n\n            // Background\n            ctx.fillStyle = \"black\";\n            ctx.fillRect(0, 0, canvas.width, canvas.height);\n\n            updateAsteroids();\n            updateBullets();\n            checkCollisions();\n            \n            drawAsteroids();\n            drawBullets();\n            drawShip();\n            \n            animationId = requestAnimationFrame(gameLoop);\n        };\n\n        document.addEventListener(\"keydown\", (e) => {\n            if (isGameOver && e.code === 'Space') {\n                resetGame();\n                return;\n            }\n            if (e.key === \"ArrowLeft\" || e.key === \"a\") ship.rotation = -TURN_SPEED;\n            if (e.key === \"ArrowRight\" || e.key === \"d\") ship.rotation = TURN_SPEED;\n            if (e.key === \"ArrowUp\" || e.key === \"w\") ship.thrusting = true;\n            if (e.code === \"Space\") shoot();\n        });\n\n        document.addEventListener(\"keyup\", (e) => {\n            if (e.key === \"ArrowLeft\" || e.key === \"a\" || e.key === \"ArrowRight\" || e.key === \"d\") ship.rotation = 0;\n            if (e.key === \"ArrowUp\" || e.key === \"w\") ship.thrusting = false;\n        });\n\n        // Touch controls\n        const handleTouchStart = (action) => (e) => { e.preventDefault(); action(); };\n        const handleTouchEnd = (action) => (e) => { e.preventDefault(); action(); };\n        \n        document.getElementById('btn-left').addEventListener('pointerdown', handleTouchStart(() => ship.rotation = -TURN_SPEED));\n        document.getElementById('btn-left').addEventListener('pointerup', handleTouchEnd(() => ship.rotation = 0));\n        \n        document.getElementById('btn-right').addEventListener('pointerdown', handleTouchStart(() => ship.rotation = TURN_SPEED));\n        document.getElementById('btn-right').addEventListener('pointerup', handleTouchEnd(() => ship.rotation = 0));\n        \n        document.getElementById('btn-up').addEventListener('pointerdown', handleTouchStart(() => ship.thrusting = true));\n        document.getElementById('btn-up').addEventListener('pointerup', handleTouchEnd(() => ship.thrusting = false));\n        \n        document.getElementById('btn-shoot').addEventListener('pointerdown', handleTouchStart(() => {\n            if(isGameOver) resetGame();\n            else shoot();\n        }));\n\n        const initGame = async () => {\n            if (window.GameAPI) {\n                try {\n                    // Load progress\n                    const progressDataStr = await window.GameAPI.getProgress();\n                    if (progressDataStr) {\n                        const progress = JSON.parse(progressDataStr);\n                        if (progress.highScore) {\n                            highScore = progress.highScore;\n                        }\n                    }\n                    \n                    // Load level\n                    const currentLevelInfo = await window.GameAPI.getCurrentLevel();\n                    if (currentLevelInfo && currentLevelInfo.levelHtml) {\n                        try {\n                           const levelData = JSON.parse(currentLevelInfo.levelHtml);\n                           document.getElementById('level-title').innerText = levelData.title || ('Asteroids - Level ' + currentLevelInfo.levelNumber);\n                           if (levelData.asteroidsCount) {\n                               roidsTotal = levelData.asteroidsCount;\n                           }\n                           if (levelData.asteroidsSpeed) {\n                               roidsSpeed = levelData.asteroidsSpeed;\n                           }\n                        } catch(e) {\n                           document.getElementById('level-title').innerText = 'Asteroids - Level ' + currentLevelInfo.levelNumber;\n                        }\n                    }\n                } catch(e) {\n                    console.error('Error initing Game API', e);\n                }\n            }\n            resetGame();\n        };\n\n        // Initialize when API is ready\n        if (window.GameAPI) {\n            initGame();\n        } else {\n            window.addEventListener('GameAPIReady', initGame);\n        }\n    </script>\n</body>\n</html>\n",
  "levels": [
    {
      "levelNumber": 1,
      "levelHtml": "{\"title\":\"Level 1: Rookie\",\"asteroidsCount\":3,\"asteroidsSpeed\":1}"
    },
